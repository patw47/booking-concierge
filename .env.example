# === OpenAI — Dedicated demo key with spend limit ===
OPENAI_API_KEY=sk-...

# === Google Sheets — Calendar availability ===
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=property-cm-agent-key.json  # Service account key (gitignored)
GOOGLE_SHEET_RANGE=Calendrier!A2:B                      # Sheet tab + range: col A=arrival, col B=departure

# === Telegram — Booking request notifications (bot the-concierge, same as property-cm) ===
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# === Transport (optional — overrides --transport CLI flag) ===
PIPECAT_TRANSPORT=webrtc

# === Session guard (seconds — 180 for demo, 300 for testing) ===
SESSION_TIMEOUT_SECS=180

# === Privacy & logging ===
# Set to 0 to disable transcript JSONL files (event log is always on).
TRANSCRIPT_LOGGING=1
# Days to retain log files before auto-purge (startup sweep + daily systemd timer).
LOG_RETENTION_DAYS=30

# === WebRTC ICE / NAT traversal ===
# STUN: Google public STUN (default, covers most networks incl. standard NAT)
STUN_SERVER=stun:stun.l.google.com:19302
# TURN: required for strict symmetric NAT (e.g. some 4G networks).
# Install coturn (see deploy/coturn.conf) then fill these.
TURN_HOST=
TURN_PORT=3478
TURN_USER=
TURN_CREDENTIAL=
