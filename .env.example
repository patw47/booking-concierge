# === OpenAI — Dedicated demo key with spend limit ===
OPENAI_API_KEY=sk-...

# === Google Sheets — Calendar availability ===
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=property-cm-agent-key.json  # Service account key (gitignored)
GOOGLE_SHEET_RANGE=Calendrier!A2:B                      # Sheet tab + range: col A=arrival, col B=departure

# === Telegram — Booking request notifications (bot the-concierge, same as property-cm) ===
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# === Transport (optional — overrides --transport CLI flag) ===
PIPECAT_TRANSPORT=webrtc

# === Session guard (seconds) ===
SESSION_TIMEOUT_SECS=300
